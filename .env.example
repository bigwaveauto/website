# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.
#
# Anything that needs to reach the browser belongs in
# src/environments/environment.ts instead (e.g. the Supabase publishable
# anon key). This file is for SERVER-ONLY secrets.

# ── Supabase ────────────────────────────────────────────────────────────────
# Server uses SERVICE_KEY (full DB access — never expose to browser).
# Browser uses the publishable anon key from src/environments/environment.ts.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...

# ── Transactional email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=no-reply@yourdomain.com

# ── Anthropic (server-side AI calls only) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── App-level encryption (AES-256-CBC) ──────────────────────────────────────
# Used for encrypted columns in Supabase. 32 random bytes, hex-encoded.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: rotating this invalidates existing encrypted data.
ENCRYPTION_KEY=

# ── DealerCenter CRM (lead + credit app posting) ────────────────────────────
DEALERCENTER_API_TOKEN=
DEALERCENTER_DEALER_ID=NOWCOM

# ── Chrome extensions (Auction Scout + Auction Grabber) ─────────────────────
# Shared secret between the server and the extension popups. Must match what
# the user enters in each extension's "API Key" field.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BWA_EXT_API_KEY=

# ── Google OAuth (Gmail receipt sync) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://bigwaveauto.com/api/auth/gmail/callback

# ── Plaid (bank transaction sync) ───────────────────────────────────────────
# Get credentials from dashboard.plaid.com → Team → Keys
# Use 'sandbox' for testing, 'production' for live bank data
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Optional / has defaults ─────────────────────────────────────────────────
# CALENDLY_URL=https://calendly.com/your-account/30min
# VAUTO_DIR=/home/vauto/inventory
# PORT=4000
